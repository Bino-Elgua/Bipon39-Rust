      "range": "1-88",
      "canonical": [ ... ],    // 88 Yorùbá strings
      "encoding": [ ... ]      // 88 ASCII strings, same order
    },
    // ... 6 more macros
  },
  "flat_index": [              // 256 objects, index 1–256
    {
      "index": 1,
